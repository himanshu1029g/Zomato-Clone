# ==========================================
# Zomato Clone - Environment Configuration
# ==========================================
# Copy this file to .env and update values as needed

# Application Settings
NODE_ENV=production
APP_NAME=zomato-clone
APP_PORT=8080
APP_HOST=0.0.0.0

# Docker Configuration
DOCKER_REGISTRY=him1029g
DOCKER_IMAGE_NAME=zomato_clone
DOCKER_IMAGE_TAG=latest

# Jenkins Configuration (Optional)
JENKINS_URL=http://localhost:8080/
JENKINS_AGENT_NAME=vinod

# DockerHub Credentials (Do NOT commit actual credentials)
# DOCKERHUB_USERNAME=your_username
# DOCKERHUB_PASSWORD=your_password
# DOCKERHUB_EMAIL=your_email@example.com

# AWS Configuration (Optional)
AWS_REGION=eu-north-1
AWS_INSTANCE_TYPE=t3.small

# Nginx Configuration
NGINX_WORKER_PROCESSES=auto
NGINX_GZIP=on
NGINX_CACHE_VALID=7d

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Security
ENABLE_HTTPS=false
ENABLE_AUTH=false

# Performance
MAX_UPLOAD_SIZE=100M
CONNECTION_TIMEOUT=60
READ_TIMEOUT=60

# Application Features
FEATURE_RESTAURANT_SEARCH=true
FEATURE_LOCATION_FILTER=true
FEATURE_ADD_RESTAURANT=true
